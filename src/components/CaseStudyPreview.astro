---
type CaseStudyImage = {
  url: string;
  alt: string;
  source: string;
  credit: string;
  license: string;
};

type CaseStudyMetric = {
  label: string;
  value: string;
};

type CaseStudy = {
  name: string;
  slug: string;
  image: CaseStudyImage;
  excerpt: string;
  industry: string;
  region: string;
  client_type: string;
  services: string[];
  solutions: string[];
  buyer_personas: string[];
  timeline: string;
  challenge: string[];
  approach: string[];
  outcomes: string[];
  metrics?: CaseStudyMetric[];
};

const featuredSlugs = [
  "ai-governance-control-framework-tier-1-indonesian-bank",
  "resilient-data-platform-national-logistics-group",
  "digital-resilience-operating-model-energy-utilities-operator",
];

const eyebrow = "Selected evidence";
const headline = "Three engagements, three proof points.";
const subline =
  "Each case shows the problem, the intervention, and the measurable operating change. Enough context for executives to judge fit before a full review.";
const cta = { label: "View all case studies", href: "/case-studies" };
const helper =
  "Full case studies include challenge, approach, outcomes, and supporting evidence.";

let allStudies: CaseStudy[] = [];
try {
  const raw = import.meta.glob("../data/*.jsonl", {
    query: "?raw",
    import: "default",
    eager: true,
  });
  const content = Object.values(raw)[0];
  if (typeof content === "string") {
    allStudies = content
      .trim()
      .split("\n")
      .map((line) => JSON.parse(line) as CaseStudy);
  }
} catch {
  allStudies = [];
}

const featured = featuredSlugs
  .map((slug) => allStudies.find((s) => s.slug === slug))
  .filter(Boolean) as CaseStudy[];

const formatStudyMeta = (study: CaseStudy) =>
  `${study.industry} • ${study.region} • ${study.timeline}`;
---

<section
  id="case-studies"
  class="bg-surface py-section-lg dark:bg-brand-950 relative overflow-hidden"
  aria-labelledby="cs-preview-headline"
>
  <div class="section-shell">
    <div
      class="mx-auto grid gap-12 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)] lg:items-start lg:gap-16"
    >
      <header class="text-left" data-csp-header>
        <p
          class="text-accent-500 mb-5 inline-block text-[0.6875rem] font-semibold tracking-[0.12em] uppercase"
        >
          {eyebrow}
        </p>

        <h2
          id="cs-preview-headline"
          class="font-display text-h2 text-brand-900 font-headline max-w-[18ch] leading-[1.05] tracking-[-0.025em] dark:text-neutral-50"
        >
          {headline}
        </h2>

        <p
          class="text-body-lg mt-5 max-w-[52ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
        >
          {subline}
        </p>

        <a
          href={cta.href}
          class="bg-brand-700 text-surface hover:bg-brand-900 focus-visible:outline-brand-500 mt-10 inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-7 py-[0.875rem] text-base font-semibold no-underline shadow-[var(--shadow-button)] transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 active:translate-y-px"
        >
          <span>{cta.label}</span>
          <svg
            class="size-4"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>

        <p
          class="mt-3 max-w-[38ch] text-sm leading-6 text-neutral-500 dark:text-neutral-400"
        >
          {helper}
        </p>
      </header>

      <ul
        class="divide-y divide-neutral-200 dark:divide-white/10"
        data-csp-list
        aria-label={featured.length > 0
          ? "Three featured case studies"
          : undefined}
      >
        {
          featured.length > 0 ? (
            featured.map((study, i) => {
              const topMetric = study.metrics?.[0];

              return (
                <li
                  data-csp-item
                  class={i === featured.length - 1 ? "last:pb-0" : ""}
                >
                  <article class="py-7 lg:py-6">
                    <a
                      href={`/case-studies/${study.slug}`}
                      class="group focus-visible:outline-brand-500 dark:focus-visible:outline-accent-500 grid gap-5 rounded-[var(--radius-card)] focus-visible:outline-2 focus-visible:outline-offset-2 sm:grid-cols-[8rem_minmax(0,1fr)] sm:gap-6"
                    >
                      <div class="dark:ring-brand-800/70 relative aspect-[4/3] overflow-hidden rounded-[var(--radius-card)] ring-1 ring-neutral-200 sm:aspect-square sm:size-[8rem]">
                        <img
                          src={study.image.url}
                          alt={study.image.alt}
                          loading="lazy"
                          decoding="async"
                          class="size-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                        />
                      </div>

                      <div class="min-w-0">
                        <p class="text-caption font-mono tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400">
                          {formatStudyMeta(study)}
                        </p>

                        <h3 class="text-brand-900 mt-2 font-sans text-[1.0625rem] leading-[1.3] font-semibold tracking-[-0.01em] dark:text-neutral-100">
                          {study.name}
                        </h3>

                        <p class="text-body-sm mt-2 max-w-[52ch] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                          {study.outcomes[0] ?? study.excerpt}
                        </p>

                        <div class="mt-4 flex flex-wrap items-center gap-x-6 gap-y-2">
                          {topMetric ? (
                            <dl class="flex items-baseline gap-1.5">
                              <dt class="sr-only">{topMetric.label}</dt>
                              <dd class="text-brand-900 font-mono text-[1.0625rem] leading-none font-semibold tracking-[-0.02em] tabular-nums dark:text-neutral-50">
                                {topMetric.value}
                              </dd>
                              <span
                                aria-hidden="true"
                                class="text-caption leading-[1.4] text-neutral-500 dark:text-neutral-400"
                              >
                                {topMetric.label}
                              </span>
                            </dl>
                          ) : (
                            <span class="text-caption font-mono tracking-[0.08em] text-neutral-400 uppercase dark:text-neutral-500">
                              {study.client_type}
                            </span>
                          )}

                          <span class="text-brand-700 dark:text-brand-200 group-hover:text-brand-900 dark:group-hover:text-brand-100 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors duration-[var(--duration-fast)]">
                            Read case study
                            <svg
                              class="size-4 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-0.5"
                              aria-hidden="true"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                              />
                            </svg>
                          </span>
                        </div>
                      </div>
                    </a>
                  </article>
                </li>
              );
            })
          ) : (
            <li data-csp-item class="py-7 lg:py-6">
              <div class="rounded-[var(--radius-card)] border border-dashed border-neutral-300 bg-neutral-50 p-6 dark:border-white/10 dark:bg-white/5">
                <p class="text-brand-900 font-sans text-[1.0625rem] leading-[1.35] font-semibold tracking-[-0.01em] dark:text-neutral-100">
                  Featured case studies are not available yet.
                </p>
                <p class="text-body-sm mt-2 max-w-[52ch] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                  Add published study data to `src/data/crn_case_studies.jsonl`
                  to populate this section.
                </p>
                <a
                  href={cta.href}
                  class="text-brand-700 hover:text-brand-900 dark:text-brand-200 dark:hover:text-brand-100 focus-visible:outline-brand-500 dark:focus-visible:outline-accent-500 mt-4 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2"
                >
                  {cta.label}
                  <svg
                    class="size-4"
                    aria-hidden="true"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                    />
                  </svg>
                </a>
              </div>
            </li>
          )
        }
      </ul>
    </div>
  </div>
</section>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("case-studies");
  if (section && !prefersReducedMotion) {
    let timeline: gsap.core.Timeline | undefined;
    let scrollTrigger: ScrollTrigger | undefined;
    let didCleanup = false;

    const cleanup = () => {
      didCleanup = true;
      scrollTrigger?.kill();
      timeline?.kill();
    };

    window.addEventListener("pagehide", cleanup, { once: true });
    document.addEventListener("astro:before-swap", cleanup, { once: true });

    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      if (didCleanup) {
        return;
      }

      const header = section.querySelector<HTMLElement>("[data-csp-header]");
      const items = section.querySelectorAll<HTMLElement>("[data-csp-item]");

      timeline = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
        defaults: { ease: "expo.out" },
      });

      scrollTrigger = timeline.scrollTrigger;

      if (header) {
        timeline.fromTo(
          header.children,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, stagger: 0.1 },
          0,
        );
      }

      if (items.length) {
        timeline.fromTo(
          items,
          { opacity: 0, y: 16 },
          {
            opacity: 1,
            y: 0,
            duration: 0.45,
            stagger: 0.12,
            ease: "power3.out",
          },
          0.3,
        );
      }

      if (didCleanup) {
        cleanup();
      }
    })();
  }
</script>
