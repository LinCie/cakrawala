---
const eyebrow = "Competitive position";

const headline =
  "Local fluency. Global discipline. Implementation accountability.";

const subline =
  "Three structural advantages that multinational consultancies cannot localize and local integrators cannot replicate.";

const pillars = [
  {
    number: "01",
    title: "Indonesian Regulatory Fluency",
    proof:
      "OJK, PDP (UU PDP), BSSN, and Kominfo requirements mapped into governance frameworks by default, not as an afterthought.",
    bullets: [
      "Regulatory taxonomy built into every assessment phase, not bolted on.",
      "Bilingual delivery teams with sector-specific control mapping.",
      "Procurement language, approval chains, and documentation norms are native, not translated.",
    ],
  },
  {
    number: "02",
    title: "Governance-to-Implementation Continuity",
    proof:
      "A single accountability chain from board mandate through to controlled production launch, with no handoff gap between advisory and delivery.",
    bullets: [
      "Named methodology with phase-gated evidence outputs.",
      "Advisory and implementation share the same governance model and control vocabulary.",
      "No strategy-to-delivery translation loss; the team that diagnoses carries the scope through.",
    ],
    emphasis: true,
  },
  {
    number: "03",
    title: "Audit-Grade Evidence Delivery",
    proof:
      "Every phase produces documented controls evidence for procurement review, audit submission, and executive reporting.",
    bullets: [
      "Controls documentation and evidence packs are standard deliverables, not extras.",
      "Executive dashboards connect technical posture to board-readable risk language.",
      "Audit-trail outputs at each gate reduce review cycles and procurement friction.",
    ],
  },
];

const cta = { label: "Assess Governance Readiness", href: "/contact" };
---

<section
  id="differentiators"
  class="bg-surface py-section-lg dark:bg-brand-950 relative overflow-hidden"
  aria-labelledby="differentiators-headline"
>
  <div class="section-shell">
    <div
      class="mx-auto grid max-w-[var(--container-enterprise)] gap-12 lg:grid-cols-[minmax(0,0.88fr)_minmax(0,1.12fr)] lg:items-start lg:gap-16"
    >
      <header class="text-left" data-diff-header>
        <p
          class="text-accent-500 mb-5 inline-block text-[0.6875rem] font-semibold tracking-[0.12em] uppercase"
        >
          {eyebrow}
        </p>

        <h2
          id="differentiators-headline"
          class="font-display text-h2 text-brand-900 font-headline max-w-[16ch] leading-[1.05] tracking-[-0.025em] dark:text-neutral-50"
        >
          {headline}
        </h2>

        <p
          class="text-body-lg mt-5 max-w-[52ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
        >
          {subline}
        </p>

        <a
          href={cta.href}
          class="bg-brand-700 text-surface hover:bg-brand-900 focus-visible:outline-brand-500 mt-10 inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-7 py-[0.875rem] text-base font-semibold no-underline shadow-[var(--shadow-button)] transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 active:translate-y-px"
        >
          <span>{cta.label}</span>
          <svg
            class="size-4"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>

        <p
          class="mt-3 max-w-[38ch] text-sm leading-6 text-neutral-500 dark:text-neutral-400"
        >
          Start with scope, control gaps, and delivery path.
        </p>
      </header>

      <ul
        class="divide-y divide-neutral-200 dark:divide-white/10"
        data-diff-pillars
        aria-label="Three CRN differentiators"
      >
        {
          pillars.map((pillar) => (
            <li
              class:list={["py-7 first:pt-0", pillar.emphasis ? "lg:py-8" : ""]}
              data-diff-pillar
            >
              <article class="grid gap-4 sm:grid-cols-[3.75rem_minmax(0,1fr)] sm:gap-6">
                <div class="flex items-start gap-3 sm:block">
                  <span
                    class="text-accent-500 font-mono text-[0.75rem] font-semibold tracking-[0.1em]"
                    aria-hidden="true"
                  >
                    {pillar.number}
                  </span>

                  {pillar.emphasis && (
                    <span class="text-accent-500 mt-[0.15rem] text-[0.6875rem] font-semibold tracking-[0.12em] uppercase sm:mt-3 sm:block">
                      Core operating model
                    </span>
                  )}
                </div>

                <div>
                  <h3 class="text-brand-900 font-sans text-[1.0625rem] leading-[1.3] font-medium tracking-[-0.01em] dark:text-neutral-100">
                    {pillar.title}
                  </h3>

                  <p class="mt-3 max-w-[52ch] text-[0.9375rem] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                    {pillar.proof}
                  </p>

                  <ul class="mt-4 space-y-2" aria-label={pillar.title}>
                    {pillar.bullets.map((bullet) => (
                      <li class="text-body-sm flex items-start gap-3 leading-[1.65] text-neutral-600 dark:text-neutral-300">
                        <span
                          class="bg-accent-500 mt-[0.5rem] size-1.5 shrink-0 rounded-full"
                          aria-hidden="true"
                        />
                        {bullet}
                      </li>
                    ))}
                  </ul>
                </div>
              </article>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("differentiators");
  if (!section) throw new Error("differentiators section not found");

  const header = section.querySelector<HTMLElement>("[data-diff-header]");
  const pillars = section.querySelectorAll<HTMLElement>("[data-diff-pillar]");

  if (!prefersReducedMotion) {
    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 72%",
          once: true,
        },
        defaults: { ease: "expo.out" },
      });

      if (header) {
        tl.fromTo(
          header.children,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, stagger: 0.1 },
          0,
        );
      }

      if (pillars.length) {
        tl.fromTo(
          pillars,
          { opacity: 0, y: 16 },
          {
            opacity: 1,
            y: 0,
            duration: 0.45,
            stagger: 0.12,
          },
          0.3,
        );
      }
    })();
  }
</script>
