---
// Final CTA close sequence for homepage
// Targets CIO/CTO evaluators with decision-support framing
// 3-beat structure: next-step explainer → contact options → authority CTA
---

<section id="final-cta" class="section-shell py-20 lg:py-28">
  <!-- Beat 1: Next-step explainer -->
  <div class="mb-16 max-w-3xl" data-fcta-intro>
    <p
      class="text-accent-700 text-caption mb-4 font-semibold tracking-wide uppercase"
    >
      Next Step
    </p>
    <h2
      class="font-display text-h2 text-brand-900 font-headline mb-6 leading-tight tracking-tight"
    >
      Bring the program, policy, or platform decision into focus.
    </h2>
    <p class="text-body-lg text-readable mb-8 leading-relaxed text-neutral-700">
      If you've reached this point, you're evaluating whether CRN can bridge the
      gap between board ambition and operational delivery. We can. Here's what
      happens next.
    </p>

    <!-- 3-step process -->
    <div class="grid gap-6 sm:grid-cols-3">
      <div class="flex flex-col" data-fcta-step>
        <span class="text-data text-brand-700 mb-2 font-bold">1</span>
        <h3 class="text-title text-brand-900 mb-2 font-semibold">
          Review Context
        </h3>
        <p class="text-body-sm leading-relaxed text-neutral-600">
          We understand your program scope, regulatory constraints, and
          current-state architecture.
        </p>
      </div>
      <div class="flex flex-col" data-fcta-step>
        <span class="text-data text-brand-700 mb-2 font-bold">2</span>
        <h3 class="text-title text-brand-900 mb-2 font-semibold">
          Align Stakeholders
        </h3>
        <p class="text-body-sm leading-relaxed text-neutral-600">
          We clarify the operating decision and the evidence your board and risk
          teams need.
        </p>
      </div>
      <div class="flex flex-col" data-fcta-step>
        <span class="text-data text-brand-700 mb-2 font-bold">3</span>
        <h3 class="text-title text-brand-900 mb-2 font-semibold">
          Define the Evidence Pack
        </h3>
        <p class="text-body-sm leading-relaxed text-neutral-600">
          We build the roadmap, control framework, and audit trail your
          organization needs.
        </p>
      </div>
    </div>
  </div>

  <!-- Beat 2: Short contact options -->
  <div class="mb-16 border-t border-neutral-200 pt-12" data-fcta-paths>
    <p
      class="text-body-sm mb-6 font-medium tracking-wide text-neutral-600 uppercase"
    >
      Choose your path
    </p>
    <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
      <a
        href="#schedule-briefing"
        class="bg-brand-700 text-surface text-body hover:bg-brand-900 focus-enterprise inline-flex items-center rounded-full px-6 py-3 font-semibold transition-colors duration-160"
      >
        Schedule Executive Briefing
      </a>
      <a
        href="#request-deck"
        class="border-brand-700 text-brand-700 text-body hover:bg-brand-50 focus-enterprise inline-flex items-center rounded-full border-2 px-6 py-3 font-semibold transition-colors duration-160"
      >
        Request Capability Deck
      </a>
      <a
        href="/contact"
        class="text-brand-700 text-body hover:text-brand-900 focus-enterprise inline-flex items-center rounded-full px-6 py-3 font-semibold transition-colors duration-160"
      >
        Use Contact Form
      </a>
    </div>
  </div>

  <!-- Beat 3: Final authority CTA panel -->
  <div
    class="rounded-panel bg-brand-950 px-8 py-12 lg:px-12 lg:py-16"
    data-fcta-panel
  >
    <div class="max-w-2xl">
      <p
        class="text-accent-500 text-caption mb-4 font-semibold tracking-wide uppercase"
      >
        Executive Briefing
      </p>
      <h3
        class="font-display text-h3 text-surface mb-6 leading-tight tracking-tight"
      >
        Reduce transformation ambiguity with a focused, evidence-led
        conversation.
      </h3>
      <p class="text-body-lg mb-8 max-w-prose leading-relaxed text-neutral-100">
        In a 60-minute executive briefing, we'll review your program scope,
        clarify the governance and control decisions ahead, and outline the
        evidence package your board and risk teams need to move forward with
        confidence.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
        <a
          href="#schedule-briefing"
          class="bg-surface text-brand-900 text-body focus-enterprise inline-flex items-center rounded-full px-8 py-3 font-semibold transition-colors duration-160 hover:bg-neutral-100"
        >
          Schedule Executive Briefing
        </a>
        <a
          href="/contact"
          class="text-surface text-body hover:border-surface focus-enterprise inline-flex items-center rounded-full border-2 border-neutral-400 px-8 py-3 font-semibold transition-colors duration-160"
        >
          Use Contact Form
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .rounded-panel {
    border-radius: var(--radius-panel);
  }

  .text-readable {
    max-width: var(--crn-readable-measure);
  }

  .max-w-prose {
    max-width: 72ch;
  }
</style>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("final-cta");
  if (!section) throw new Error("final-cta section not found");

  const intro = section.querySelector<HTMLElement>("[data-fcta-intro]");
  const steps = section.querySelectorAll<HTMLElement>("[data-fcta-step]");
  const paths = section.querySelector<HTMLElement>("[data-fcta-paths]");
  const panel = section.querySelector<HTMLElement>("[data-fcta-panel]");

  const allTargets = [intro, ...steps, paths, panel].filter(
    Boolean,
  ) as HTMLElement[];

  if (prefersReducedMotion) {
    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(allTargets, { opacity: 1, y: 0 });
    })();
  } else {
    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
        defaults: { ease: "power2.out" },
      });

      if (intro) {
        tl.fromTo(
          intro.children,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, stagger: 0.08 },
          0,
        );
      }

      if (steps.length) {
        tl.fromTo(
          steps,
          { opacity: 0, y: 14 },
          { opacity: 1, y: 0, duration: 0.4, stagger: 0.1, ease: "power3.out" },
          0.25,
        );
      }

      if (paths) {
        tl.fromTo(
          paths,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.4 },
          0.5,
        );
      }

      if (panel) {
        tl.fromTo(
          panel,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" },
          0.65,
        );
      }
    })();
  }
</script>
