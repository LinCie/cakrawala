---
const sectionEyebrow = "Executive briefings";
const sectionHeadline = "Decision-grade analysis for regulated enterprises.";
const sectionCopy =
  "Sample briefings that show how CRN translates AI governance, data protection, and cloud regulation into operating decisions for boards, risk teams, and technical leaders.";
const primaryCta = { label: "Start a conversation", href: "#contact" };

const leadInsight = {
  topic: "AI governance",
  title: "What OJK\u2019s AI Governance Guidance Means for Indonesian Banks",
  summary:
    "The April 2025 guidance sets baseline expectations for model inventory, risk classification, human oversight, and audit trails. Banks scaling AI pilots need lifecycle controls before review cycles begin.",
  format: "Board briefing",
  date: "May 2026",
};

const supportingInsights = [
  {
    topic: "Data protection",
    title: "PDP readiness: move from legal obligation to data operating model",
    description:
      "Build mapping, consent workflows, and breach response into the operating model, not a checklist.",
  },
  {
    topic: "Cloud risk",
    title:
      "Cloud data residency in Indonesia: the architecture questions that matter",
    description:
      "Use landing zone design, data classification, and audit evidence to separate residency claims from actual control.",
  },
];
---

<section
  id="insights-preview"
  class="py-section-sm dark:bg-brand-950 lg:py-section-md bg-neutral-50"
  aria-labelledby="insights-headline"
>
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-start lg:gap-16">
      <div class="lg:col-span-5" data-ip-intro>
        <p
          class="text-accent-700 mb-5 inline-block text-[0.6875rem] font-semibold tracking-[0.12em] uppercase"
        >
          {sectionEyebrow}
        </p>

        <h2
          id="insights-headline"
          class="font-display text-h2 text-brand-900 font-headline max-w-[22ch] leading-[1.05] tracking-[-0.025em] lg:max-w-[20ch] dark:text-neutral-50"
        >
          {sectionHeadline}
        </h2>

        <p
          class="text-body-lg mt-5 max-w-[52ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
        >
          {sectionCopy}
        </p>

        <div class="mt-10">
          <a
            href={primaryCta.href}
            class="bg-brand-700 text-surface hover:bg-brand-900 focus-visible:outline-brand-700 dark:focus-visible:outline-accent-500 inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-7 py-[0.875rem] text-base font-semibold no-underline shadow-[var(--shadow-button)] transition-colors duration-[var(--duration-fast)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 active:translate-y-px"
          >
            <span>{primaryCta.label}</span>
            <svg
              class="size-4"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
            </svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <article
          class="rounded-panel border-brand-200 bg-brand-50/70 shadow-card dark:border-brand-800/70 dark:bg-brand-950/55 border p-6 md:p-7"
          data-ip-lead
        >
          <div class="flex flex-wrap items-center gap-2">
            <span
              class="text-caption text-accent-700 dark:text-accent-500 font-mono tracking-[0.08em] uppercase"
            >
              {leadInsight.topic}
            </span>
            <span
              class="text-caption border-brand-100 bg-surface dark:border-brand-800 dark:bg-brand-950/80 rounded-full border px-2.5 py-1 font-medium tracking-[0.06em] text-neutral-500 uppercase dark:text-neutral-400"
            >
              {leadInsight.format}
            </span>
            <span class="text-caption text-neutral-500 dark:text-neutral-400">
              {leadInsight.date}
            </span>
          </div>

          <h3
            class="text-brand-900 text-h4 mt-3 leading-[1.25] font-semibold tracking-[-0.02em] dark:text-neutral-100"
          >
            {leadInsight.title}
          </h3>

          <p
            class="mt-3 max-w-[60ch] leading-[1.65] text-neutral-700 dark:text-neutral-300"
          >
            {leadInsight.summary}
          </p>
        </article>

        <ul
          class="divide-brand-100 dark:divide-brand-800/70 mt-5 divide-y"
          data-ip-support
        >
          {
            supportingInsights.map((item) => (
              <li data-ip-support-item class="py-4 first:pt-0 last:pb-0">
                <div class="min-w-0">
                  <p class="text-caption text-accent-700 dark:text-accent-500 font-mono tracking-[0.08em] uppercase">
                    {item.topic}
                  </p>

                  <h3 class="text-brand-900 text-body-lg mt-2 leading-[1.3] font-semibold tracking-[-0.015em] dark:text-neutral-100">
                    {item.title}
                  </h3>
                </div>

                <p class="mt-2 max-w-[58ch] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                  {item.description}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("insights-preview");
  if (!section) throw new Error("insights-preview section not found");

  const intro = section.querySelector<HTMLElement>("[data-ip-intro]");
  const lead = section.querySelector<HTMLElement>("[data-ip-lead]");
  const supportItems = section.querySelectorAll<HTMLElement>(
    "[data-ip-support-item]",
  );

  const allTargets = [intro, lead, ...supportItems].filter(
    Boolean,
  ) as HTMLElement[];

  if (prefersReducedMotion) {
    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);
      gsap.registerPlugin(ScrollTrigger);
      gsap.set(allTargets, { opacity: 1, y: 0 });
    })();
  } else {
    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: section,
          start: "top 75%",
          once: true,
        },
        defaults: { ease: "power2.out" },
      });

      if (intro) {
        tl.fromTo(
          intro.children,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.45, stagger: 0.08 },
          0,
        );
      }

      if (lead) {
        tl.fromTo(
          lead,
          { opacity: 0, y: 16 },
          { opacity: 1, y: 0, duration: 0.5 },
          0.18,
        );
      }

      if (supportItems.length) {
        tl.fromTo(
          supportItems,
          { opacity: 0, y: 12 },
          { opacity: 1, y: 0, duration: 0.4, stagger: 0.1, ease: "power3.out" },
          0.34,
        );
      }
    })();
  }
</script>
