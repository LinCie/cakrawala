---
const sectionEyebrow = "Analyst desk";
const sectionHeadline = "Decision-grade analysis for regulated enterprises.";
const sectionCopy =
  "Briefings and frameworks that translate AI governance, data protection, and cloud regulation into operating decisions for boards, risk teams, and technical leaders.";

const leadInsight = {
  topic: "AI governance",
  title: "What OJK\u2019s AI Governance Guidance Means for Indonesian Banks",
  summary:
    "The April 2025 guidance sets baseline expectations for model inventory, risk classification, human oversight, and audit trails. Banks scaling AI pilots need lifecycle controls before review cycles begin.",
  format: "Board briefing",
  date: "May 2026",
  focus: "Focus: control ownership, evidence readiness, and review cadence.",
};

const supportingInsights = [
  {
    topic: "Data protection",
    title: "PDP readiness: move from legal obligation to data operating model",
    description:
      "Build mapping, consent workflows, and breach response into the operating model, not a checklist.",
    focus: "Operating model",
  },
  {
    topic: "Cloud risk",
    title:
      "Cloud data residency in Indonesia: the architecture questions that matter",
    description:
      "Use landing zone design, data classification, and audit evidence to separate residency claims from actual control.",
    focus: "Architecture review",
  },
];

const cta = { label: "Start a conversation", href: "#contact" };
---

<section
  id="insights-preview"
  class="py-section-sm dark:bg-brand-950 lg:py-section-md bg-neutral-50"
  aria-labelledby="insights-headline"
>
  <div class="section-shell">
    <div class="grid gap-12 lg:grid-cols-12 lg:items-start lg:gap-16">
      <div class="lg:col-span-5" data-ip-intro>
        <p
          class="text-accent-500 mb-5 inline-block text-[0.6875rem] font-semibold tracking-[0.12em] uppercase"
        >
          {sectionEyebrow}
        </p>

        <h2
          id="insights-headline"
          class="font-display text-h2 text-brand-900 max-w-[22ch] leading-[1.05] font-semibold tracking-[-0.025em] lg:max-w-[20ch] dark:text-neutral-50"
        >
          {sectionHeadline}
        </h2>

        <p
          class="text-body-lg mt-5 max-w-[52ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
        >
          {sectionCopy}
        </p>

        <a
          href={cta.href}
          class="bg-brand-700 text-surface hover:bg-brand-900 focus-visible:outline-brand-700 dark:focus-visible:outline-accent-500 mt-10 inline-flex min-h-11 items-center justify-center gap-2 rounded-full px-7 py-[0.875rem] text-base font-semibold no-underline shadow-[var(--shadow-button)] transition-colors duration-[var(--duration-fast)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 active:translate-y-px"
        >
          <span>{cta.label}</span>
          <svg
            class="size-4"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>

      <div class="lg:col-span-7">
        <article
          class="rounded-panel border-brand-200 bg-brand-50/70 shadow-card dark:border-brand-800/70 dark:bg-brand-950/55 border p-6 md:p-7"
          data-ip-lead
        >
          <div class="flex flex-wrap items-center gap-2">
            <span
              class="text-caption text-accent-700 dark:text-accent-500 font-mono tracking-[0.08em] uppercase"
            >
              {leadInsight.topic}
            </span>
            <span
              class="text-caption border-brand-100 bg-surface dark:border-brand-800 dark:bg-brand-950/80 rounded-full border px-2.5 py-1 font-medium tracking-[0.06em] text-neutral-500 uppercase dark:text-neutral-400"
            >
              {leadInsight.format}
            </span>
            <span class="text-caption text-neutral-500 dark:text-neutral-400">
              {leadInsight.date}
            </span>
          </div>

          <h3
            class="text-brand-900 text-h4 mt-3 leading-[1.25] font-semibold tracking-[-0.02em] dark:text-neutral-100"
          >
            {leadInsight.title}
          </h3>

          <p
            class="mt-3 max-w-[60ch] leading-[1.65] text-neutral-700 dark:text-neutral-300"
          >
            {leadInsight.summary}
          </p>

          <p
            class="text-body-sm text-brand-900/80 mt-5 max-w-[52ch] leading-[1.65] dark:text-neutral-200"
          >
            {leadInsight.focus}
          </p>
        </article>

        <ul
          class="divide-brand-100 dark:divide-brand-800/70 mt-5 divide-y"
          data-ip-support
        >
          {
            supportingInsights.map((item) => (
              <li class="py-4 first:pt-0 last:pb-0">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-caption text-accent-700 dark:text-accent-500 font-mono tracking-[0.08em] uppercase">
                      {item.topic}
                    </p>

                    <h3 class="text-brand-900 text-body-lg mt-2 leading-[1.3] font-semibold tracking-[-0.015em] dark:text-neutral-100">
                      {item.title}
                    </h3>
                  </div>

                  <span class="text-caption dark:border-brand-800 dark:bg-brand-950/70 rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 font-medium tracking-[0.06em] text-neutral-500 uppercase dark:text-neutral-400">
                    {item.focus}
                  </span>
                </div>

                <p class="mt-2 max-w-[58ch] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                  {item.description}
                </p>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<script>
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  const section = document.getElementById("insights-preview");

  if (section && !prefersReducedMotion) {
    let context: { revert: () => void } | undefined;
    let didCleanup = false;

    const cleanup = () => {
      didCleanup = true;
      context?.revert();
    };

    window.addEventListener("pagehide", cleanup, { once: true });
    document.addEventListener("astro:before-swap", cleanup, { once: true });

    void (async () => {
      const [{ default: gsap }, { ScrollTrigger }] = await Promise.all([
        import("gsap"),
        import("gsap/ScrollTrigger"),
      ]);

      gsap.registerPlugin(ScrollTrigger);

      if (didCleanup || !section.isConnected) {
        return;
      }

      context = gsap.context(() => {
        const intro = section.querySelector("[data-ip-intro]");
        const lead = section.querySelector("[data-ip-lead]");
        const supportItems = section.querySelectorAll("[data-ip-support] > *");

        const timeline = gsap.timeline({
          scrollTrigger: {
            trigger: section,
            start: "top 78%",
            once: true,
          },
          defaults: { ease: "expo.out" },
        });

        if (intro) {
          timeline.from(intro, {
            opacity: 0,
            y: 20,
            duration: 0.5,
          });
        }

        if (lead) {
          timeline.from(
            lead,
            {
              opacity: 0,
              y: 20,
              duration: 0.5,
            },
            intro ? "-=0.15" : 0,
          );
        }

        if (supportItems.length > 0) {
          timeline.from(
            supportItems,
            {
              opacity: 0,
              y: 16,
              duration: 0.4,
              stagger: 0.08,
            },
            lead ? "-=0.1" : 0,
          );
        }
      }, section);
    })();
  }
</script>
