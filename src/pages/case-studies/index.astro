---
import Base from "../../layouts/Base.astro";

const siteUrl = Astro.site?.toString() || "https://crnadvisory.id";

type CaseStudyImage = {
  url: string;
  alt: string;
  source: string;
  credit: string;
  license: string;
};

type CaseStudyMetric = {
  label: string;
  value: string;
  description?: string;
};

type CaseStudy = {
  name: string;
  slug: string;
  image: CaseStudyImage;
  excerpt: string;
  industry: string;
  region: string;
  client_type: string;
  services: string[];
  solutions: string[];
  buyer_personas: string[];
  timeline: string;
  challenge: string[];
  approach: string[];
  outcomes: string[];
  metrics?: CaseStudyMetric[];
};

let allStudies: CaseStudy[] = [];
try {
  const raw = import.meta.glob("../../data/*.jsonl", {
    query: "?raw",
    import: "default",
    eager: true,
  });
  const preferredDataPath = Object.keys(raw).find((path) =>
    path.endsWith("/crn_case_studies.jsonl"),
  );
  const fallbackPath = Object.keys(raw).sort()[0];
  const content = raw[preferredDataPath || fallbackPath || ""];
  if (typeof content === "string") {
    allStudies = content
      .trim()
      .split("\n")
      .map((line) => JSON.parse(line) as CaseStudy);
  }
} catch {
  allStudies = [];
}

const uniqueIndustries = [...new Set(allStudies.map((s) => s.industry))].sort();
const uniquePersonas = [
  ...new Set(allStudies.flatMap((s) => s.buyer_personas)),
].sort();
const uniqueServices = [
  ...new Set(allStudies.flatMap((s) => s.services)),
].sort();
const uniqueSolutions = [
  ...new Set(allStudies.flatMap((s) => s.solutions)),
].sort();
const uniqueRegions = [...new Set(allStudies.map((s) => s.region))].sort();

const caseStudiesSchema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Case Studies",
        item: `${siteUrl}/case-studies`,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Case Studies",
    description:
      "Enterprise transformation evidence from CRN Advisory Systems engagements across banking, logistics, energy, healthcare, and regulated Indonesian sectors.",
    url: `${siteUrl}/case-studies`,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: allStudies.map((study, idx) => ({
        "@type": "ListItem",
        position: idx + 1,
        url: `${siteUrl}/case-studies/${study.slug}`,
        name: study.name,
      })),
    },
  },
];
---

<Base
  title="Case Studies | CRN Advisory Systems"
  description="Enterprise transformation evidence from CRN Advisory System engagements across banking, logistics, energy, healthcare, and regulated Indonesian sectors."
  seo={{
    openGraph: {
      basic: {
        title: "Case Studies — CRN Advisory Systems",
        description:
          "Evidence of governed AI, data platform modernization, cloud risk, and digital resilience programs for Indonesian enterprises.",
      },
    },
  }}
  schema={caseStudiesSchema}
>
  <main class="pt-[var(--crn-header-height)]">
    <section
      class="dark:border-brand-800/70 dark:bg-surface-inverse border-b border-neutral-200 bg-neutral-50"
    >
      <div class="section-shell py-section-lg" data-animate="hero-shell">
        <div class="max-w-[var(--container-prose)]">
          <p
            data-animate="hero-eyebrow"
            class="text-accent-700 dark:text-accent-500 text-caption font-semibold tracking-[0.12em] uppercase"
          >
            Client Evidence
          </p>
          <h1
            data-animate="hero-title"
            class="font-display text-h1 text-brand-900 mt-4 leading-[1] font-semibold tracking-[-0.035em] dark:text-neutral-100"
          >
            Governed intelligence, measurable outcomes.
          </h1>
          <p
            data-animate="hero-copy"
            class="text-body-lg text-readable mt-5 leading-[1.7] text-neutral-600 dark:text-neutral-300"
          >
            Each engagement below shows the problem, the intervention, and the
            operating change. These fictional case studies demonstrate how CRN
            applies structured governance to AI, data, cloud, and resilience
            programs across regulated Indonesian enterprises.
          </p>
          <p
            data-animate="hero-note"
            class="text-body-sm mt-4 max-w-[58ch] leading-[1.65] text-neutral-500 dark:text-neutral-400"
          >
            <em
              >Note: All case studies are fictional examples created for
              demonstration purposes. Client identities and specific metrics
              have been anonymized.</em
            >
          </p>
        </div>
      </div>
    </section>

    <section class="section-shell py-section-md" id="case-studies-archive">
      <div
        data-animate="filter-shell"
        class="rounded-panel dark:border-brand-800/70 dark:bg-brand-950/60 lg:rounded-t-panel lg:bg-surface lg:shadow-elevated dark:lg:border-brand-800/70 dark:lg:bg-brand-950 -mx-1.5 mb-8 border border-neutral-200 bg-neutral-50 p-5 md:mb-10 md:p-6 lg:sticky lg:top-[var(--crn-header-height)] lg:z-40 lg:mb-0 lg:rounded-b-none lg:border-x-0 lg:border-t-0 lg:border-b lg:border-neutral-200 lg:p-6"
      >
        <div class="flex items-start justify-between gap-4 md:items-center">
          <div class="min-w-0 flex-1">
            <p
              class="text-caption font-semibold tracking-[0.12em] text-neutral-500 uppercase dark:text-neutral-400"
            >
              Filter by
            </p>
            <p
              class="text-body-sm mt-1 text-neutral-600 dark:text-neutral-300"
              id="results-status"
              role="status"
              aria-live="polite"
              aria-atomic="true"
            >
              <span id="result-count">All {allStudies.length} case studies</span
              >
              <span class="hidden" id="filtered-count">
                {allStudies.length} matching
              </span>
            </p>
            <p
              class="text-caption mt-1 text-neutral-500 dark:text-neutral-400"
              id="filter-logic-note"
            >
              Filters use AND logic.
            </p>
            <div
              id="active-filter-list"
              class="mt-3 flex hidden flex-wrap gap-1.5 pb-1"
            >
            </div>
          </div>

          <button
            id="filter-toggle"
            class="text-brand-700 hover:text-brand-900 focus-visible:outline-brand-500 dark:text-accent-500 dark:hover:text-accent-400 dark:focus-visible:outline-accent-500 flex items-center gap-2 text-sm font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 lg:hidden"
            aria-expanded="false"
            aria-controls="filter-panel"
          >
            <svg
              class="size-5"
              aria-hidden="true"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"
              ></path>
            </svg>
            <span id="filter-toggle-label">Show filters</span>
            <span
              id="active-filter-badge"
              class="bg-accent-500 text-surface hidden rounded-full px-2 py-0.5 text-xs font-semibold"
            >
              0
            </span>
          </button>

          <button
            id="clear-filters"
            class="text-brand-700 hover:text-brand-900 focus-visible:outline-brand-500 dark:text-brand-200 dark:focus-visible:outline-accent-500 hidden text-sm font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 disabled:cursor-not-allowed disabled:opacity-50 dark:hover:text-neutral-100"
            disabled
          >
            Clear all
          </button>
        </div>

        <div
          id="filter-panel"
          class="mt-6 hidden lg:mt-0 lg:block"
          aria-labelledby="filter-panel-heading"
        >
          <h2 id="filter-panel-heading" class="sr-only">Filter case studies</h2>

          <div class="space-y-5 lg:grid lg:grid-cols-5 lg:gap-6 lg:space-y-0">
            <div class="filter-group">
              <label
                for="industry-filter"
                class="text-caption block font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
              >
                Industry
              </label>
              <select
                id="industry-filter"
                class="bg-surface text-brand-900 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 mt-2 block w-full rounded-[var(--radius-field)] border border-neutral-300 px-3 py-2 text-sm transition-shadow duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              >
                <option value="">All industries</option>
                {
                  uniqueIndustries.map((industry) => (
                    <option value={industry}>{industry}</option>
                  ))
                }
              </select>
            </div>

            <div class="filter-group">
              <label
                for="persona-filter"
                class="text-caption block font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
              >
                Decision Owner
              </label>
              <select
                id="persona-filter"
                class="bg-surface text-brand-900 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 mt-2 block w-full rounded-[var(--radius-field)] border border-neutral-300 px-3 py-2 text-sm transition-shadow duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              >
                <option value="">All personas</option>
                {
                  uniquePersonas.map((persona) => (
                    <option value={persona}>{persona}</option>
                  ))
                }
              </select>
            </div>

            <div class="filter-group">
              <label
                for="service-filter"
                class="text-caption block font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
              >
                Service Line
              </label>
              <select
                id="service-filter"
                class="bg-surface text-brand-900 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 mt-2 block w-full rounded-[var(--radius-field)] border border-neutral-300 px-3 py-2 text-sm transition-shadow duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              >
                <option value="">All services</option>
                {
                  uniqueServices.map((service) => (
                    <option value={service}>{service}</option>
                  ))
                }
              </select>
            </div>

            <div class="filter-group">
              <label
                for="solution-filter"
                class="text-caption block font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
              >
                Solution
              </label>
              <select
                id="solution-filter"
                class="bg-surface text-brand-900 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 mt-2 block w-full rounded-[var(--radius-field)] border border-neutral-300 px-3 py-2 text-sm transition-shadow duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              >
                <option value="">All solutions</option>
                {
                  uniqueSolutions.map((solution) => (
                    <option value={solution}>{solution}</option>
                  ))
                }
              </select>
            </div>

            <div class="filter-group">
              <label
                for="region-filter"
                class="text-caption block font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
              >
                Region
              </label>
              <select
                id="region-filter"
                class="bg-surface text-brand-900 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 mt-2 block w-full rounded-[var(--radius-field)] border border-neutral-300 px-3 py-2 text-sm transition-shadow duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              >
                <option value="">All regions</option>
                {
                  uniqueRegions.map((region) => (
                    <option value={region}>{region}</option>
                  ))
                }
              </select>
            </div>
          </div>
        </div>
      </div>

      <div id="results-list" class="space-y-1" aria-hidden="false">
        {
          allStudies.map((study) => {
            const topMetric = study.metrics?.[0];
            const studyMeta = `${study.industry} • ${study.region} • ${study.timeline}`;

            return (
              <article
                data-animate="study-item"
                data-study-item
                data-industry={study.industry}
                data-region={study.region}
                data-services={JSON.stringify(study.services)}
                data-solutions={JSON.stringify(study.solutions)}
                data-personas={JSON.stringify(study.buyer_personas)}
                class="group border-b border-neutral-200 py-8 last:border-b-0 dark:border-white/10"
              >
                <a
                  href={`/case-studies/${study.slug}`}
                  class="focus-visible:outline-brand-500 dark:focus-visible:outline-accent-500 block rounded-[var(--radius-card)] focus-visible:outline-2 focus-visible:outline-offset-2"
                >
                  <div class="grid gap-4 md:grid-cols-[1fr_auto] md:items-start md:gap-6">
                    <div class="min-w-0">
                      <p class="text-caption font-mono tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400">
                        {studyMeta}
                      </p>

                      <h3 class="text-brand-900 mt-2 font-sans text-xl leading-[1.25] font-semibold tracking-[-0.015em] dark:text-neutral-100">
                        {study.name}
                      </h3>

                      <p class="text-body mt-2.5 max-w-[62ch] leading-[1.65] text-neutral-600 dark:text-neutral-300">
                        {study.outcomes[0] || study.excerpt}
                      </p>

                      <div class="mt-4 flex flex-wrap items-center gap-2">
                        {study.services.slice(0, 1).map((service) => (
                          <span class="bg-brand-50 text-brand-700 dark:border-brand-800/70 dark:bg-brand-950 dark:text-brand-200 border-brand-100 text-caption rounded-full border px-2.5 py-1 font-medium tracking-[0.04em] dark:border">
                            {service}
                          </span>
                        ))}
                        {study.solutions.slice(0, 1).map((solution) => (
                          <span class="text-caption rounded-full border border-teal-100 bg-teal-50 px-2.5 py-1 font-medium tracking-[0.04em] text-teal-700 dark:border dark:border-teal-900/50 dark:bg-teal-950/40 dark:text-teal-200">
                            {solution}
                          </span>
                        ))}
                      </div>
                    </div>

                    <div class="flex flex-col items-end gap-3 md:min-w-[140px]">
                      {topMetric ? (
                        <dl class="flex flex-col items-end gap-0.5">
                          <dt class="sr-only">{topMetric.label}</dt>
                          <dd class="text-brand-900 font-mono text-lg leading-none font-semibold tracking-[-0.02em] tabular-nums dark:text-neutral-50">
                            {topMetric.value}
                          </dd>
                          <span
                            aria-hidden="true"
                            class="text-caption text-right leading-[1.4] text-neutral-500 dark:text-neutral-400"
                          >
                            {topMetric.label}
                          </span>
                        </dl>
                      ) : (
                        <span class="text-caption text-right font-mono tracking-[0.08em] text-neutral-400 uppercase dark:text-neutral-500">
                          {study.client_type}
                        </span>
                      )}

                      <span class="text-brand-700 dark:text-brand-200 group-hover:text-brand-900 dark:group-hover:text-brand-100 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors duration-[var(--duration-fast)]">
                        Read case study
                        <svg
                          class="size-4 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-0.5"
                          aria-hidden="true"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                          />
                        </svg>
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            );
          })
        }
      </div>

      <div
        id="no-results"
        class="rounded-panel hidden border border-dashed border-neutral-300 bg-neutral-50 p-8 text-center dark:border-white/10 dark:bg-white/5"
        aria-hidden="true"
      >
        <p
          class="text-brand-900 font-sans text-lg leading-[1.35] font-semibold tracking-[-0.01em] dark:text-neutral-100"
        >
          No case studies match your filters.
        </p>
        <p
          class="text-body mx-auto mt-2 max-w-[52ch] leading-[1.65] text-neutral-600 dark:text-neutral-300"
        >
          No matching case studies found for current filters. Clear filters to
          return to all available evidence.
        </p>
        <button
          id="reset-filters"
          class="text-brand-700 hover:text-brand-900 focus-visible:outline-brand-500 dark:text-brand-200 dark:focus-visible:outline-accent-500 mt-4 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:hover:text-neutral-100"
        >
          Clear all filters
          <svg
            class="size-4"
            aria-hidden="true"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
          </svg>
        </button>
      </div>
    </section>
  </main>
</Base>

<script is:inline define:vars={{ allStudies }}>
  let studiesLoadError = false;

  function safeParseList(dataValue) {
    if (!dataValue) {
      return [];
    }
    try {
      const parsed = JSON.parse(dataValue);
      return Array.isArray(parsed) ? parsed : [];
    } catch {
      return dataValue
        .split(",")
        .map((value) => value.trim())
        .filter(Boolean);
    }
  }

  function getFilterElements() {
    return {
      industry: document.getElementById("industry-filter"),
      persona: document.getElementById("persona-filter"),
      service: document.getElementById("service-filter"),
      solution: document.getElementById("solution-filter"),
      region: document.getElementById("region-filter"),
    };
  }

  function getActiveFilters() {
    const active = {};
    const filters = getFilterElements();
    for (const [key, select] of Object.entries(filters)) {
      if (select && select.value) {
        active[key] = select.value;
      }
    }
    return active;
  }

  function updateActiveFilterBadge() {
    const activeCount = Object.keys(getActiveFilters()).length;
    const activeFilterBadge = document.getElementById("active-filter-badge");
    const clearFiltersBtn = document.getElementById("clear-filters");
    if (activeFilterBadge && clearFiltersBtn) {
      if (activeCount > 0) {
        activeFilterBadge.textContent = activeCount.toString();
        activeFilterBadge.classList.remove("hidden");
        clearFiltersBtn.classList.remove("hidden");
        clearFiltersBtn.disabled = false;
      } else {
        activeFilterBadge.classList.add("hidden");
        clearFiltersBtn.classList.add("hidden");
        clearFiltersBtn.disabled = true;
      }
    }
  }

  function updateActiveFilterList(activeFilters) {
    const activeFilterList = document.getElementById("active-filter-list");
    if (!activeFilterList) {
      return;
    }

    const filterLabels = {
      industry: "Industry",
      persona: "Decision Owner",
      service: "Service",
      solution: "Solution",
      region: "Region",
    };

    activeFilterList.innerHTML = "";
    const entries = Object.entries(activeFilters);
    if (entries.length === 0) {
      activeFilterList.classList.add("hidden");
      return;
    }

    entries.forEach(([key, value]) => {
      const chip = document.createElement("button");
      chip.type = "button";
      chip.className =
        "bg-brand-50 text-brand-700 dark:border-brand-800/70 dark:bg-brand-950 dark:text-brand-200 rounded-full border border-brand-100 px-2.5 py-1 text-[0.68rem] font-medium tracking-[0.04em]";
      chip.textContent = `${filterLabels[key] || key}: ${value} ✕`;
      chip.setAttribute(
        "aria-label",
        `Remove ${filterLabels[key] || key} filter`,
      );
      chip.addEventListener("click", () => {
        const element = document.getElementById(`${key}-filter`);
        if (element) {
          element.value = "";
          applyFilters();
        }
      });
      activeFilterList.appendChild(chip);
    });

    activeFilterList.classList.remove("hidden");
  }

  function applyFilters() {
    const activeFilters = getActiveFilters();
    const studyItems = document.querySelectorAll("[data-study-item]");
    let visibleCount = 0;

    studyItems.forEach((item) => {
      const studyIndustry = item.dataset.industry;
      const studyRegion = item.dataset.region;
      const studyServices = safeParseList(item.dataset.services);
      const studySolutions = safeParseList(item.dataset.solutions);
      const studyPersonas = safeParseList(item.dataset.personas);

      const matchesIndustry =
        !activeFilters.industry || studyIndustry === activeFilters.industry;
      const matchesRegion =
        !activeFilters.region || studyRegion === activeFilters.region;
      const matchesService =
        !activeFilters.service || studyServices.includes(activeFilters.service);
      const matchesSolution =
        !activeFilters.solution ||
        studySolutions.includes(activeFilters.solution);
      const matchesPersona =
        !activeFilters.persona || studyPersonas.includes(activeFilters.persona);

      const isVisible =
        matchesIndustry &&
        matchesRegion &&
        matchesService &&
        matchesSolution &&
        matchesPersona;

      if (isVisible) {
        item.classList.remove("hidden");
        item.setAttribute("aria-hidden", "false");
        visibleCount++;
      } else {
        item.classList.add("hidden");
        item.setAttribute("aria-hidden", "true");
      }
    });

    const resultsList = document.getElementById("results-list");
    const noResults = document.getElementById("no-results");
    const resultCount = document.getElementById("result-count");
    const filteredCount = document.getElementById("filtered-count");

    if (resultsList && noResults && resultCount && filteredCount) {
      if (visibleCount === 0) {
        resultsList.classList.add("hidden");
        resultsList.setAttribute("aria-hidden", "true");
        noResults.classList.remove("hidden");
        noResults.setAttribute("aria-hidden", "false");
        filteredCount.textContent = "0 matching";
      } else {
        resultsList.classList.remove("hidden");
        resultsList.setAttribute("aria-hidden", "false");
        noResults.classList.add("hidden");
        noResults.setAttribute("aria-hidden", "true");
        filteredCount.textContent = visibleCount + " matching";
      }

      if (Object.keys(activeFilters).length === 0) {
        resultCount.classList.remove("hidden");
        filteredCount.classList.add("hidden");
        resultCount.textContent = "All " + allStudies.length + " case studies";
      } else {
        resultCount.classList.add("hidden");
        filteredCount.classList.remove("hidden");
      }
    }

    updateActiveFilterBadge();
    updateActiveFilterList(activeFilters);
    updateURL(activeFilters);
  }

  function updateURL(activeFilters) {
    const url = new URL(window.location.href);
    const filterKeys = ["industry", "persona", "service", "solution", "region"];

    for (const key of filterKeys) {
      url.searchParams.delete(key);
    }
    for (const [key, value] of Object.entries(activeFilters)) {
      url.searchParams.set(key, value);
    }
    const newURL = url.toString();
    if (newURL !== window.location.href) {
      window.history.replaceState({}, "", newURL);
    }
  }

  function restoreFiltersFromURL() {
    const url = new URL(window.location.href);
    const filters = getFilterElements();
    for (const [key, select] of Object.entries(filters)) {
      if (select) {
        const value = url.searchParams.get(key);
        if (value && [...select.options].some((opt) => opt.value === value)) {
          select.value = value;
        }
      }
    }
    applyFilters();
  }

  function clearAllFilters() {
    const filters = getFilterElements();
    for (const select of Object.values(filters)) {
      if (select) {
        select.value = "";
      }
    }
    applyFilters();
  }

  const filters = getFilterElements();

  for (const select of Object.values(filters)) {
    if (select) {
      select.addEventListener("change", applyFilters);
    }
  }

  const clearFiltersBtn = document.getElementById("clear-filters");
  const resetFiltersBtn = document.getElementById("reset-filters");
  const filterToggle = document.getElementById("filter-toggle");
  const filterToggleLabel = document.getElementById("filter-toggle-label");
  const filterPanel = document.getElementById("filter-panel");

  if (clearFiltersBtn) {
    clearFiltersBtn.addEventListener("click", clearAllFilters);
  }

  if (resetFiltersBtn) {
    resetFiltersBtn.addEventListener("click", clearAllFilters);
  }

  if (filterToggle && filterPanel) {
    filterToggle.addEventListener("click", () => {
      const isExpanded = filterToggle.getAttribute("aria-expanded") === "true";
      const nextState = !isExpanded;
      filterToggle.setAttribute("aria-expanded", nextState.toString());
      filterPanel.classList.toggle("hidden");

      if (filterToggleLabel) {
        filterToggleLabel.textContent = nextState
          ? "Hide filters"
          : "Show filters";
      }

      if (nextState) {
        const firstFilter = document.getElementById("industry-filter");
        if (firstFilter) {
          firstFilter.focus();
        }
      } else {
        filterToggle.focus();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        const isExpanded =
          filterToggle.getAttribute("aria-expanded") === "true";
        if (isExpanded) {
          filterToggle.setAttribute("aria-expanded", "false");
          filterPanel.classList.add("hidden");
          if (filterToggleLabel) {
            filterToggleLabel.textContent = "Show filters";
          }
          filterToggle.focus();
        }
      }
    });
  }

  try {
    if (allStudies.length === 0) {
      studiesLoadError = true;
      console.error("Case studies data is empty or failed to load.");
    }
  } catch {
    studiesLoadError = true;
    console.error("Case studies data failed to initialize.");
  }

  restoreFiltersFromURL();

  if (studiesLoadError) {
    const noResults = document.getElementById("no-results");
    const resultsList = document.getElementById("results-list");
    const noResultsTitle = noResults?.querySelector("p");
    const noResultsCopy = noResults?.querySelector("p + p");
    if (noResults && resultsList) {
      resultsList.classList.add("hidden");
      resultsList.setAttribute("aria-hidden", "true");
      noResults.classList.remove("hidden");
      noResults.setAttribute("aria-hidden", "false");
      if (noResultsTitle) {
        noResultsTitle.textContent = "Case studies are unavailable right now.";
      }
      if (noResultsCopy) {
        noResultsCopy.textContent =
          "We could not load case study data. Please refresh or try again later.";
      }
    }
  }
</script>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  const selectors =
    '[data-animate="hero-eyebrow"], [data-animate="hero-title"], [data-animate="hero-copy"], [data-animate="hero-note"], [data-animate="filter-shell"], [data-animate="study-item"]';

  const revealAll = () => {
    document.querySelectorAll<HTMLElement>(selectors).forEach((el) => {
      el.style.opacity = "1";
      el.style.transform = "none";
    });
  };

  const initEntranceAnimation = () => {
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      revealAll();
      return;
    }

    gsap.registerPlugin(ScrollTrigger);

    gsap.fromTo(
      [
        '[data-animate="hero-eyebrow"]',
        '[data-animate="hero-title"]',
        '[data-animate="hero-copy"]',
        '[data-animate="hero-note"]',
      ],
      { y: 22, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.5,
        ease: "power3.out",
        stagger: 0.12,
        clearProps: "transform,opacity",
      },
    );

    gsap.fromTo(
      '[data-animate="filter-shell"]',
      { y: 18, opacity: 0 },
      {
        y: 0,
        opacity: 1,
        duration: 0.46,
        delay: 0.18,
        ease: "power3.out",
        clearProps: "transform,opacity",
      },
    );

    gsap.utils
      .toArray<HTMLElement>('[data-animate="study-item"]')
      .forEach((item) => {
        gsap.fromTo(
          item,
          { y: 24, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.48,
            ease: "power3.out",
            scrollTrigger: { trigger: item, start: "top 88%", once: true },
            clearProps: "transform,opacity",
          },
        );
      });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initEntranceAnimation, {
      once: true,
    });
  } else {
    initEntranceAnimation();
  }
</script>
