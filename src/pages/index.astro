---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";
import TrustStrip from "../components/TrustStrip.astro";
import ProblemFraming from "../components/ProblemFraming.astro";
import SolutionOverview from "../components/SolutionOverview.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import IndustryFocus from "../components/IndustryFocus.astro";
import Differentiators from "../components/Differentiators.astro";
import CaseStudyPreview from "../components/CaseStudyPreview.astro";
import TrustCenter from "../components/TrustCenter.astro";
import InsightsPreview from "../components/InsightsPreview.astro";
import FinalCta from "../components/FinalCta.astro";

const siteUrl = Astro.site?.toString() || "https://crnadvisory.id";

const homeSchema = [
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": `${siteUrl}/#organization`,
        name: "CRN Advisory Systems",
        legalName: "PT Cakrawala Reka Nusa",
        url: siteUrl,
        logo: {
          "@type": "ImageObject",
          url: `${siteUrl}/logo.png`,
          width: 512,
          height: 512,
        },
        description:
          "Enterprise AI governance, data platform modernization, cloud risk, and digital resilience consultancy for Indonesian enterprises.",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Jakarta",
          addressCountry: "ID",
        },
        contactPoint: {
          "@type": "ContactPoint",
          contactType: "Sales",
          email: "advisory@crnadvisory.id",
          availableLanguage: ["English", "Indonesian"],
        },
        sameAs: ["https://www.linkedin.com/company/crn-advisory-systems"],
      },
      {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        url: siteUrl,
        name: "CRN Advisory Systems",
        publisher: {
          "@id": `${siteUrl}/#organization`,
        },
        potentialAction: {
          "@type": "SearchAction",
          target: `${siteUrl}/search?q={search_term_string}`,
          "query-input": "required name=search_term_string",
        },
        inLanguage: ["en-ID", "id-ID"],
      },
      {
        "@type": "WebPage",
        "@id": `${siteUrl}/#webpage`,
        url: siteUrl,
        name: "CRN Advisory Systems — Governed AI, Data & Cloud Transformation Indonesia",
        isPartOf: {
          "@id": `${siteUrl}/#website`,
        },
        about: {
          "@id": `${siteUrl}/#organization`,
        },
        description:
          "Enterprise AI governance, data platform modernization, cloud risk, and digital resilience for Indonesian banks, manufacturers, and regulated enterprises.",
        inLanguage: "en-ID",
      },
    ],
  },
];
---

<Base
  title="CRN Advisory Systems — Governed AI, Data & Cloud Transformation Indonesia"
  description="Enterprise AI governance, data platform modernization, cloud risk, and digital resilience for Indonesian banks, manufacturers, and regulated enterprises."
  seo={{
    openGraph: {
      basic: {
        title:
          "CRN Advisory Systems — Governed AI & Data Transformation Indonesia",
        description:
          "Enterprise AI governance, data platforms, cloud risk, and digital resilience for Indonesian regulated enterprises.",
      },
    },
  }}
  schema={homeSchema}
>
  <main>
    <Hero />
    <TrustStrip />
    <ProblemFraming />
    <SolutionOverview />
    <ServiceGrid />
    <IndustryFocus />
    <Differentiators />
    <CaseStudyPreview />
    <TrustCenter />
    <InsightsPreview />
    <FinalCta />
  </main>
</Base>
