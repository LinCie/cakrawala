---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import TrustStrip from "../components/TrustStrip.astro";
import ProblemFraming from "../components/ProblemFraming.astro";
import SolutionOverview from "../components/SolutionOverview.astro";
import ServiceGrid from "../components/ServiceGrid.astro";
import IndustryFocus from "../components/IndustryFocus.astro";
import Differentiators from "../components/Differentiators.astro";
import CaseStudyPreview from "../components/CaseStudyPreview.astro";
import TrustCenter from "../components/TrustCenter.astro";
import InsightsPreview from "../components/InsightsPreview.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta
      name="description"
      content="CRN Advisory Systems — Indonesia's enterprise partner for governed AI, resilient data platforms, cloud risk, and digital resilience."
    />
    <title>
      CRN Advisory Systems — Governed Intelligence for Resilient Enterprise
      Operations
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;650&family=IBM+Plex+Mono:wght@400;500;600&family=Satoshi:wght@650&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
    <main>
      <Header />
      <Hero />
      <TrustStrip />
      <ProblemFraming />
      <SolutionOverview />
      <ServiceGrid />
      <IndustryFocus />
      <Differentiators />
      <CaseStudyPreview />
      <TrustCenter />
      <InsightsPreview />
      <section
        id="contact"
        class="flex h-screen items-center justify-center px-6 text-center"
      >
        <div class="max-w-[42rem]">
          <p
            class="text-accent-700 mb-3 text-[0.6875rem] font-semibold tracking-[0.12em] uppercase"
          >
            Contact
          </p>
          <h2
            class="font-display text-h2 text-brand-900 leading-[1.05] font-semibold tracking-[-0.025em] dark:text-neutral-100"
          >
            Start the conversation with CRN Advisory Systems.
          </h2>
          <p
            class="text-body-lg mt-5 leading-[1.7] text-neutral-600 dark:text-neutral-300"
          >
            Bring us the program, policy, or control problem. We will help shape
            the operating decision and the evidence package.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>

<style is:global>
  ::selection {
    background-color: var(--color-brand-700);
    color: var(--color-surface);
  }

  html {
    scroll-behavior: smooth;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }

  ::-webkit-scrollbar {
    width: 10px;
    height: 10px;
  }

  ::-webkit-scrollbar-track {
    background: var(--color-neutral-100);
  }

  ::-webkit-scrollbar-thumb {
    background: var(--color-neutral-400);
    border-radius: 5px;
    border: 2px solid var(--color-neutral-100);
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--color-neutral-500);
  }

  [data-theme="dark"] ::-webkit-scrollbar-track {
    background: var(--color-brand-950);
  }

  [data-theme="dark"] ::-webkit-scrollbar-thumb {
    background: var(--color-brand-700);
    border-color: var(--color-brand-950);
  }

  [data-theme="dark"] ::-webkit-scrollbar-thumb:hover {
    background: var(--color-brand-600);
  }
</style>
