---
import Base from "../../layouts/Base.astro";
import { industries, sectorClusters } from "../../data/industries";

const siteUrl = Astro.site?.toString() || "https://crnadvisory.id";

/*
 * Load rich industry data from JSONL when available.
 * Falls back to the baseline industries.ts framing if JSONL cannot be resolved.
 * Logs a console warning in non-production when rich data is missing.
 */
let industriesRich: Record<string, any> = {};
try {
  const richPath = new URL("../../data/crn-industries.jsonl", import.meta.url);
  const res = await fetch(richPath);
  if (res.ok) {
    const text = await res.text();
    const parsed = text
      .trim()
      .split("\n")
      .map((line) => {
        try {
          return JSON.parse(line);
        } catch {
          return null;
        }
      })
      .filter(Boolean);
    for (const entry of parsed) {
      if (entry?.slug) industriesRich[entry.slug] = entry;
    }
  }
} catch (e) {
  if (import.meta.env.DEV) {
    // Visible fallback notice during development
    console.warn(
      "[industries] Rich data unavailable, using baseline framing.",
      e,
    );
  }
}

/* Build enriched entries: merge JSONL detail onto baseline framing */
interface EnrichedIndustry {
  index: string;
  name: string;
  slug: string;
  framing: string;
  subtitle: string;
  excerpt: string;
  image: string;
  imageAlt: string;
  primaryBuyers: string[];
  challenges: Array<{ title: string }>;
  crnFocus: string[];
  marketFit: string[];
  _richMissing: boolean;
}

const enrichedIndustries: EnrichedIndustry[] = industries.map((ind) => {
  const rich = industriesRich[ind.slug];
  if (!rich) {
    return {
      ...ind,
      subtitle: ind.framing,
      excerpt: `${ind.framing} — CRN helps organisations in this sector assess readiness and build a governed roadmap.`,
      image: "",
      imageAlt: "",
      primaryBuyers: [],
      challenges: [],
      crnFocus: [],
      marketFit: [],
      _richMissing: true,
    };
  }
  return {
    index: ind.index,
    name: ind.name,
    slug: ind.slug,
    framing: ind.framing,
    subtitle: rich.subtitle || ind.framing,
    excerpt:
      rich.excerpt ||
      `${ind.framing} — CRN helps organisations in this sector assess readiness and build a governed roadmap.`,
    image: rich.image || "",
    imageAlt: rich.imageAlt || "",
    primaryBuyers: Array.isArray(rich.primaryBuyers) ? rich.primaryBuyers : [],
    challenges: Array.isArray(rich.challenges) ? rich.challenges : [],
    crnFocus: Array.isArray(rich.crnFocus) ? rich.crnFocus : [],
    marketFit: Array.isArray(rich.marketFit) ? rich.marketFit : [],
    _richMissing: false,
  };
});

const enrichedMap = Object.fromEntries(
  enrichedIndustries.map((e) => [e.slug, e]),
);

/* Schema.org structured data */
const industriesSchema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: siteUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Industries",
        item: `${siteUrl}/industries`,
      },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "Industry Solutions",
    description:
      "Sector-specific enterprise transformation solutions for Indonesian regulated industries",
    url: `${siteUrl}/industries`,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: sectorClusters.flatMap((cluster, clusterIdx) =>
        cluster.sectors.map((industry, sectorIdx) => ({
          "@type": "ListItem",
          position: clusterIdx * 10 + sectorIdx + 1,
          url: `${siteUrl}/industries/${industry.slug}`,
        })),
      ),
    },
  },
];

const metaDescription =
  "Sector-specific AI, data, cloud, and resilience solutions for banking, manufacturing, logistics, energy, healthcare, telecommunications, SOEs, and conglomerates in Indonesia.";

/* Decision-path labels for the guidance strip */
const decisionPaths = [
  {
    label: "Regulatory pressure",
    description: "Compliance-first: OJK, PDP, MAS guidelines",
    icon: "scale-balanced",
    clusterMatch: ["Regulated accountabilities"],
  },
  {
    label: "Operational complexity",
    description: "Multi-site, multi-entity coordination",
    icon: "sitemap",
    clusterMatch: ["Operating complexity"],
  },
  {
    label: "Infrastructure criticality",
    description: "Zero-tolerance for downtime or data loss",
    icon: "bolt",
    clusterMatch: ["Critical infrastructure"],
  },
] as const;
---

<Base
  title="Industries | CRN Advisory Systems"
  description={metaDescription}
  seo={{
    openGraph: {
      basic: {
        title: "Industry Solutions — CRN Advisory Systems",
        description: metaDescription,
      },
    },
  }}
  schema={industriesSchema}
>
  <main class="pt-[var(--crn-header-height)]">
    {/* ===== Hero Band ===== */}
    <section
      class="dark:border-brand-800/70 dark:bg-surface-inverse border-b border-neutral-200 bg-neutral-50"
    >
      <div class="section-shell py-section-lg">
        <div class="max-w-[var(--container-prose)]">
          <p
            class="text-accent-700 dark:text-accent-500 text-caption font-semibold tracking-[0.12em] uppercase"
          >
            Industries
          </p>
          <h1
            class="font-display text-h1 text-brand-900 mt-4 leading-[1] font-semibold tracking-[-0.035em] dark:text-neutral-100"
          >
            Designed for sectors where governance<br
              class="hidden sm:block"
            />is part of the operating model.
          </h1>
          <p
            class="text-body-lg text-readable mt-5 leading-[1.7] text-neutral-600 dark:text-neutral-300"
          >
            CRN Advisory Structures every engagement around sector-specific
            regulatory constraints, data environments, and operational risk
            profiles — not generic transformation playbooks.
          </p>
          <p
            class="text-body-lg text-readable mt-2 leading-[1.7] text-neutral-600 dark:text-neutral-300"
          >
            Find your sector below, or start with the path that matches your
            most pressing concern.
          </p>

          {/* Primary CTA: anchored to conversion panel below */}
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              class="bg-brand-700 text-surface shadow-button hover:bg-brand-900 focus-visible:outline-brand-500 inline-flex items-center rounded-full px-6 py-3 font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2"
              href="#start-here"
            >
              Find your starting point
            </a>
            <a
              class="bg-surface text-brand-900 hover:border-brand-200 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 dark:hover:border-brand-700 inline-flex items-center rounded-full border border-neutral-200 px-6 py-3 font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2 dark:text-neutral-100"
              href="#sectors"
            >
              Browse all sectors
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* ===== Sticky Jump Nav ===== */}
    <nav
      class="dark:border-brand-800/70 dark:bg-brand-950/90 lg:sticky lg:top-[var(--crn-header-height)] z-40 border-b border-neutral-200 bg-white/90 backdrop-blur-[8px] motion-reduce:backdrop-blur-none"
      aria-label="Industry cluster navigation"
    >
      <div class="section-shell flex flex-col items-start gap-2 py-3 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <span
          class="text-caption font-semibold tracking-[0.08em] text-neutral-500 uppercase dark:text-neutral-400"
        >
          Jump to cluster
        </span>
        <div class="scrollbar-hide -mx-1 flex w-full gap-2 overflow-x-auto px-1 pb-1 sm:mx-0 sm:w-auto sm:px-0 sm:pb-0">
          {
            sectorClusters.map((cluster) => (
              <a
                href={`#cluster-${cluster.label.toLowerCase().replace(/\s+/g, "-")}`}
                class="hover:bg-brand-50 hover:border-brand-200 hover:text-brand-700 dark:border-brand-800/70 dark:bg-brand-950/60 dark:hover:border-brand-700 inline-flex min-h-[44px] shrink-0 items-center rounded-full border border-neutral-200 bg-neutral-50 px-3 py-1.5 text-xs font-medium tracking-[0.02em] whitespace-nowrap text-neutral-700 transition-colors duration-[var(--duration-fast)] max-[359px]:px-2.5 max-[359px]:py-1 max-[359px]:text-[0.7rem] max-[359px]:tracking-[0.01em] dark:hover:text-neutral-100"
              >
                {cluster.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    {/* ===== Decision-Path Strip ===== */}
    <section id="start-here" class="section-shell py-section-lg">
      <div
        class="rounded-panel bg-surface shadow-card dark:border-brand-800/70 dark:bg-brand-950 border border-neutral-200 p-6 md:p-8"
      >
        <p
          class="text-caption font-semibold tracking-[0.12em] text-neutral-500 uppercase dark:text-neutral-400"
        >
          Not sure where to start?
        </p>
        <h2
          class="font-display text-h3 text-brand-900 mt-2 leading-[1.08] font-semibold tracking-[-0.025em] dark:text-neutral-100"
        >
          Pick the concern that matches your situation.
        </h2>
        <p
          class="text-body-sm mt-3 max-w-[58ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
        >
          Each path leads to the sectors where that concern is most acute — and
          the specific controls, evidence, and architecture CRN would address.
        </p>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {
            decisionPaths.map((path) => (
              <a
                href={`#cluster-${path.clusterMatch[0].toLowerCase().replace(/\s+/g, "-")}`}
                class="group rounded-card hover:border-brand-200 hover:bg-brand-50/60 dark:border-brand-800/70 dark:bg-brand-950/60 dark:hover:border-brand-700 inline-flex min-h-[44px] flex-col items-start justify-center border border-neutral-200 bg-neutral-50 p-5 transition-colors duration-[var(--duration-fast)]"
              >
                <div class="flex items-center gap-3">
                  <span
                    class="text-brand-700 dark:text-accent-500 text-xl leading-none"
                    aria-hidden="true"
                  >
                    {path.icon === "scale-balanced" && (
                      <svg
                        class="size-5 shrink-0"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M12 3v18m-9-9h18"
                        />
                      </svg>
                    )}
                    {path.icon === "sitemap" && (
                      <svg
                        class="size-5 shrink-0"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M3.75 13.5h16.5m-16.5 3h16.5m-16.5-6h16.5"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M3.75 6.75h8.25"
                        />
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M12 6.75h8.25"
                        />
                      </svg>
                    )}
                    {path.icon === "bolt" && (
                      <svg
                        class="size-5 shrink-0"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
                        />
                      </svg>
                    )}
                  </span>
                  <span class="text-body text-brand-900 group-hover:text-brand-700 font-semibold dark:text-neutral-100">
                    {path.label}
                  </span>
                </div>
                <p class="text-body-sm mt-2 leading-[1.65] text-neutral-600 dark:text-neutral-400">
                  {path.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    {/* ===== Cluster Sections ===== */}
    <section id="sectors" class="section-shell py-section-lg">
      <div class="space-y-10">
        {
          sectorClusters.map((cluster) => {
            const clusterId = cluster.label.toLowerCase().replace(/\s+/g, "-");
            return (
              <section
                id={`cluster-${clusterId}`}
                class:list={[
                  "rounded-panel border p-6 md:p-8",
                  cluster.tone === "tint"
                    ? "border-brand-100 bg-brand-50/70 dark:border-brand-800/70 dark:bg-brand-950/60"
                    : "bg-surface shadow-card dark:border-brand-800/70 dark:bg-brand-950 border-neutral-200",
                ]}
              >
                {/* Cluster header */}
                <div class="mb-6 flex flex-wrap items-start justify-between gap-3">
                  <div class="flex items-center gap-3">
                    <span
                      class="bg-accent-500 size-2 shrink-0 rounded-full"
                      aria-hidden="true"
                    />
                    <p class="text-caption font-semibold tracking-[0.12em] text-neutral-500 uppercase dark:text-neutral-400">
                      {cluster.label}
                    </p>
                  </div>
                  <span class="text-caption dark:border-brand-800/70 dark:bg-brand-950 ml-auto rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 font-medium tracking-[0.04em] text-neutral-500 uppercase dark:text-neutral-400">
                    {cluster.sectors.length} sector
                    {cluster.sectors.length > 1 ? "s" : ""}
                  </span>
                </div>

                <h2 class="font-display text-h3 text-brand-900 leading-[1.08] font-semibold tracking-[-0.025em] dark:text-neutral-100">
                  {cluster.title}
                </h2>

                <p class="text-body-sm mt-3 max-w-[58ch] leading-[1.7] text-neutral-600 dark:text-neutral-300">
                  {cluster.summary}
                </p>

                {/* Sector entries */}
                <ul class="mt-8 space-y-3" role="list">
                  {cluster.sectors.map((industry) => {
                    const rich = enrichedMap[industry.slug];
                    const topChallenge = rich?.challenges?.[0]?.title || null;
                    const buyerSummary =
                      rich?.primaryBuyers?.length > 0
                        ? rich.primaryBuyers.slice(0, 3).join(", ")
                        : null;

                    return (
                      <li data-animate="sector-item">
                        <a
                          class="group bg-surface hover:border-brand-200 focus-visible:outline-brand-500 dark:border-brand-800/70 dark:bg-brand-950 dark:hover:border-brand-700 flex items-start gap-4 rounded-[var(--radius-card)] border border-neutral-200 px-4 py-4 transition-colors duration-[var(--duration-fast)] hover:shadow-xs focus-visible:outline-2 focus-visible:outline-offset-2"
                          href={`/industries/${industry.slug}`}
                        >
                          {/* Index badge */}
                          <span
                            class="text-brand-700 bg-brand-50 border-brand-100 text-caption dark:border-brand-800/70 dark:bg-brand-900 dark:text-accent-500 flex size-10 shrink-0 items-center justify-center rounded-full border font-mono font-medium tracking-[0.08em]"
                            aria-hidden="true"
                          >
                            {industry.index}
                          </span>

                          {/* Content */}
                          <span class="min-w-0 flex-1">
                            <span class="flex flex-wrap items-center gap-2">
                              <span class="text-body text-brand-900 leading-[1.3] font-semibold tracking-[-0.01em] dark:text-neutral-100">
                                {industry.name}
                              </span>
                            </span>

                            {/* Subtitle / framing */}
                            <span class="text-body-sm mt-1 block leading-[1.65] text-neutral-600 dark:text-neutral-300">
                              {rich?.subtitle || industry.framing}
                            </span>

                            {/* Challenge + buyers row */}
                            <span class="text-body-xs mt-2 flex flex-wrap gap-x-4 gap-y-1 text-neutral-500 dark:text-neutral-400">
                              {topChallenge && (
                                <span class="flex items-start gap-1">
                                  <svg
                                    class="mt-0.5 size-3 shrink-0 text-neutral-400 dark:text-neutral-500"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z"
                                    />
                                  </svg>
                                  {topChallenge}
                                </span>
                              )}
                              {buyerSummary && (
                                <span class="flex items-start gap-1">
                                  <svg
                                    class="mt-0.5 size-3 shrink-0 text-neutral-400 dark:text-neutral-500"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                    aria-hidden="true"
                                  >
                                    <path
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
                                    />
                                  </svg>
                                  {buyerSummary}
                                </span>
                              )}
                            </span>
                          </span>

                          {/* Arrow */}
                          <svg
                            class="text-brand-500 dark:text-accent-500 mt-0.5 size-4 shrink-0 transition-transform duration-[var(--duration-fast)] group-hover:translate-x-0.5"
                            aria-hidden="true"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                            />
                          </svg>
                        </a>
                      </li>
                    );
                  })}
                </ul>

                {/* Cluster-level CTA */}
                <div class="dark:border-brand-800/70 mt-6 flex flex-wrap gap-3 border-t border-neutral-100 pt-4">
                  <a
                    class="bg-brand-700 text-surface shadow-button hover:bg-brand-900 focus-visible:outline-brand-500 inline-flex items-center rounded-full px-5 py-2.5 text-sm font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2"
                    href="/#contact"
                  >
                    Book a sector briefing
                  </a>
                  <a
                    class="text-body-sm text-brand-700 hover:text-brand-900 dark:text-accent-500 dark:hover:text-accent-400 inline-flex items-center gap-1 font-medium transition-colors duration-[var(--duration-fast)]"
                    href={`/industries/${cluster.sectors[0].slug}`}
                  >
                    Explore {cluster.sectors.length}{" "}
                    {cluster.sectors.length > 1 ? "sectors" : "sector"}
                    <svg
                      class="size-3.5 shrink-0"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                      />
                    </svg>
                  </a>
                </div>
              </section>
            );
          })
        }
      </div>
    </section>

    {/* ===== Conversion Panel ===== */}
    <section class="section-shell py-section-lg">
      <div
        class="rounded-panel bg-surface shadow-card dark:border-brand-800/70 dark:bg-brand-950 border border-neutral-200 p-6 md:p-8"
      >
        <div class="max-w-[var(--container-prose)]">
          <h2
            class="font-display text-h3 text-brand-900 leading-[1.08] font-semibold tracking-[-0.025em] dark:text-neutral-100"
          >
            Ready to discuss your sector's requirements?
          </h2>
          <p
            class="text-body mt-4 max-w-[58ch] leading-[1.7] text-neutral-600 dark:text-neutral-300"
          >
            CRN Advisory Systems helps regulated and operationally complex
            organisations modernize AI, data platforms, cloud environments, and
            digital operations with executive-grade governance and
            implementation discipline. One briefing, one concise memo, one
            recommended next step.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            {/* Primary CTA */}
            <a
              class="bg-brand-700 text-surface shadow-button hover:bg-brand-900 focus-visible:outline-brand-500 inline-flex items-center rounded-full px-6 py-3 font-semibold transition-colors duration-[var(--duration-fast)] focus-visible:outline-2 focus-visible:outline-offset-2"
              href="/#contact"
            >
              Schedule an Executive Briefing
            </a>
            {/* Secondary CTA: informational, visually subordinate */}
            <a
              class="text-body-sm inline-flex items-center gap-1.5 font-medium text-neutral-600 underline decoration-neutral-300 underline-offset-4 transition-colors duration-[var(--duration-fast)] hover:text-neutral-800 dark:text-neutral-400 dark:decoration-neutral-700 dark:hover:text-neutral-200"
              href="/capabilities"
            >
              <svg
                class="size-3.5 shrink-0"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M12 10v6m0 0l-3-3m3 3 3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
              Download the Capability Deck (PDF)
            </a>
          </div>
        </div>
      </div>
    </section>
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const items = document.querySelectorAll<HTMLElement>(
        "[data-animate='sector-item']",
      );

      if (prefersReducedMotion) {
        gsap.set(items, { opacity: 1, y: 0 });
      } else {
        gsap.utils.toArray<HTMLElement>(items).forEach((item) => {
          gsap.fromTo(
            item,
            { opacity: 0, y: 20 },
            {
              opacity: 1,
              y: 0,
              duration: 0.48,
              ease: "power3.out",
              scrollTrigger: {
                trigger: item,
                start: "top 88%",
                once: true,
              },
              clearProps: "transform,opacity",
            },
          );
        });
      }
    </script>
  </main>
</Base>
